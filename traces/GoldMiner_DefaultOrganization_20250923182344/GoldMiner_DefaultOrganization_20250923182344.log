        self._transitioning = True
        try:
            if evt is not None:
                evt.preventDefault()
        except Exception:
            pass
        try:
            self.btn_next.disabled = True
            self.btn_retry.disabled = True
        except Exception:
            pass
        # Retry same level
        self.start_level(self.level_index)
        self.start()

    def on_keydown(self, evt):
