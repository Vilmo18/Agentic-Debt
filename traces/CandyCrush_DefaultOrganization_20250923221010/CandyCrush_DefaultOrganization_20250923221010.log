'''
Stylesheet for Match-3 game UI and candy visuals.
'''
:root {
  --bg: #0f1226;
  --panel: #171a33;
  --accent: #6c6ff8;
  --accent-2: #67e3f7;
  --text: #e9ecff;
  --muted: #9aa3c8;
