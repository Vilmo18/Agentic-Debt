  transition: transform 0.05s ease, background-color 0.2s ease, opacity 0.2s ease;
}
button.primary { background: linear-gradient(135deg, var(--accent), #4c4ff3); }
button.secondary { background: linear-gradient(135deg, #2a2e5e, #232654); }
button:hover { transform: translateY(-1px); }
button:disabled { opacity: 0.6; cursor: not-allowed; }

main {
  max-width: 900px; margin: 24px auto; padding: 12px; position: relative;
}

.message {
  min-height: 22px; text-align: center; color: var(--muted); margin-bottom: 8px;
}

.board {
  width: max-content; margin: 10px auto; padding: 10px; background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08); border-radius: 12px;
  display: grid; gap: var(--gap);
}

.tile {
  width: var(--tile-size); height: var(--tile-size);
  border-radius: var(--radius);
