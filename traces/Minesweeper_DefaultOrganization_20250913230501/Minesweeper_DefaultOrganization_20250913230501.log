NUMBER_COLORS = {
    1: "#1e90ff",  # DodgerBlue
    2: "#228B22",  # ForestGreen
    3: "#dc143c",  # Crimson
    4: "#00008b",  # DarkBlue
    5: "#8b0000",  # DarkRed
    6: "#008b8b",  # DarkCyan
    7: "#000000",  # Black
    8: "#696969",  # DimGray
}
FLAG_CHAR = "🚩"  # Distinct visual for flagged cells
