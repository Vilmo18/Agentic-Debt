  border-radius: 10px;
  padding: 12px 14px;
  box-shadow: 0 8px 18px var(--shadow), inset 0 0 0 1px rgba(255,255,255,0.04);
}
.panel h2 {
  margin: 0 0 10px;
  font-size: 16px;
  color: var(--accent);
}
#next {
