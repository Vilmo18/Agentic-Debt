}
.controls {
  margin: 0;
  padding-left: 18px;
  color: var(--muted);
}
.buttons {
  display: flex;
  gap: 8px;
  justify-content: space-between;
}
button {
  flex: 1;
  background: var(--btn);
  color: var(--text);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 8px;
