 {\n    const ctx = this.renderer.boardCtx;\n    const w = this.cols * this.cellSize;\n    const h = this.rows * this.cellSize;\n    ctx.save();\n    ctx.fillStyle = \'rgba(0,0,0,0.6)\';\n    ctx.fillRect(0, 0, w, h);\n    ctx.fillStyle = \'#ffffff\';\n    ctx.textAlign = \'center\';\n    ctx.shadowColor = \'rgba(0,0,0,0.6)\';\n    ctx.shadowBlur = 8;\n    ctx.font = \'bold 28px system-ui, sans-serif\';\n    ctx.fillText(title, w / 2, h / 2 - 8);\n    ctx.font = \'16px system-ui, sans-serif\';\n    ctx.fillText(subtitle, w / 2, h / 2 + 18);\n    ctx.restore();\n  }\n}\n\n\n', 'images': '', 'comments': "Highest-priority comment: The lock delay timer is being incremented in two places in game.js (inside the gravity/drop block and again in the on-ground block), which can cause pieces to lock faster than intended and inconsistently, especially at higher levels. This violates expected Tetris behavior and can make gameplay feel unfair.\n\nHow to fix:\n- Only manage the lock delay timer in one place: the on-ground section. Remove any lockTimer increments from the gravity/drop branch. Also avoid force-starting the timer in inputSoftDrop; let the on-ground logic handle it uniformly.\n\nConcrete changes:\n1) In game.js, in update(dt), replace the gravity section with:\n- If gravity move succeeds, reset lockTimer to 0.\n- If gravity move fails, do not touch lockTimer here; let the on-ground section handle it.\n\nFrom:\n  if (this.dropTimer &gt;= this.dropInterval) {\n    this.dropTimer = 0;\n    if (this.active) {\n      if (!this.active.tryMove(this.board, 0, 1)) {\n        this.lockTimer += dt || this.dropInterval;\n        if (this.lockTimer === 0) this.lockTimer = 1;\n      } else {\n        this.lockTimer = 0;\n      }\n    }\n  }\n\nTo:\n  if (this.dropTimer &gt;= this.dropInterval) {\n    this.dropTimer = 0;\n    if (this.active) {\n      if (this.active.tryMove(this.board, 0, 1)) {\n        // successful gravity move resets lock timer\n        this.lockTimer = 0;\n    