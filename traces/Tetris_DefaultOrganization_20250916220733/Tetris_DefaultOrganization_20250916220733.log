      [0, 1, 0],
    ],
  ],
};
export const COLORS = {
  I: '#40c4ff', // cyan
  O: '#ffd740', // yellow
  T: '#b388ff', // purple
  S: '#69f0ae', // green
  Z: '#ff5252', // red
  J: '#448aff', // blue
  L: '#ffab40', // orange
};
// Optional spawn offsets per piece to better center on spawn (in grid cells)
export const SPAWN_OFFSETS = {
  I: -1,
  O: 0,
  T: 0,
  S: 0,
  Z: 0,
  J: 0,
  L: 0,
};
export const TYPES = Object.keys(SHAPES);
