  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.controls {
  margin: 0;
  padding-left: 18px;
  color: var(--muted);
}
.buttons {
  display: flex;
  gap: 8px;
  justify-content: space-between;
}
button {
