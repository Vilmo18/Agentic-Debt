}
.game-area {
  display: grid;
  grid-template-columns: auto 260px;
  gap: 16px;
  align-items: start;
}
#board {
  display: block;
  background: #0e0f15;
  border-radius: 8px;
  box-shadow: 0 10px 24px var(--shadow), inset 0 0 0 1px rgba(255,255,255,0.06);
}
.sidebar {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.panel {
  background: var(--panel);
  border-radius: 10px;
  padding: 12px 14px;
  box-shadow: 0 8px 18px var(--shadow), inset 0 0 0 1px rgba(255,255,255,0.04);
}
.panel h2 {
  margin: 0 0 10px;
  font-size: 16px;
  color: var(--accent);
}
#next {
  display: block;
  background: #0e0f15;
  border-radius: 6px;
  width: 100%;
  height: auto;
}
.stats {
  display: grid;
  gap: 6px;
}
.stats > div {
  display: flex;
  justify-content: space-between;
  color: var(--text);
  font-variant-numeric: tabular-nums;
}
.controls {
  margin: 0;
  padding-left: 18px;
  color: var(--muted);
}
.buttons {
  display: flex;
  gap: 8px;
  justify-content: space-between;
}
button {
  flex: 1;
  background: var(--btn);
  color: var(--text);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 8px;
  padding: 10px 12px;
  cursor: pointer;
  transition: background 0.15s ease, transform 0.05s ease;
}
button:hover {
  background: var(--btn-hover);
}
button:active {
  transform: translateY(1px);
}
footer {
  margin-top: 16px;
  color: var(--muted);
  text-align: center;
  font-size: 12px;
}
@media (max-width: 840px) {
  .game-area {
    grid-template-columns: 1fr;
  }
  #board {
    margin: 0 auto;
  }
}
