+            is_left: True if left paddle, False if right paddle.
+        """
+        pre_vx_sign = -1 if is_left else 1  # vx should become positive after left, negative after right
+        # Compute relative impact point (-1 at top, +1 at bottom)
+        rel = (self.y - paddle.center_y) / (paddle.rect.height / 2.0)
+        rel = _clamp(rel, -1.0, 1.0)
+        # Target speed after collision (with speed-up)
+        self._increase_speed()
+        speed = math.hypot(self.vx, self.vy)
+        # Set vy influenced by where it hit the paddle, then recompute vx to maintain speed
+        self.vy = rel * speed * 0.8  # 80% of speed to vertical component based on impact
