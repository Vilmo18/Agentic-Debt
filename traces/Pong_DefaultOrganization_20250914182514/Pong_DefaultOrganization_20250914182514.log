 Paddle and Ball with movement, rendering, and collision behavior.\n\'\'\'\nimport math\nimport random\nimport pygame\nfrom typing import Tuple\ndef _clamp(value: float, lo: float, hi: float) -&gt; float:\n    """Clamp a float value to the [lo, hi] range."""\n    return max(lo, min(hi, value))\nclass Paddle:\n    """\n    Represents a vertical Pong paddle controlled by the player.\n    """\n    def __init__(self, x: int, y: int, width: int, height: int, speed: float, screen_height: int):\n        """\n        Initialize the paddle.\n        Args:\n            x: Left coordinate of the paddle.\n            y: Top coordinate of the paddle.\n            width: Paddle width in pixels.\n            height: Paddle height in pixels.\n            speed: Movement speed in pixels per second.\n            screen_height: Screen height to clamp movement.\n        """\n        self._rect = pygame.Rect(x, y, width, height)\n        self.speed = speed\n        self.screen_height = screen_height\n        self._direction = 0  # -1 (up), 0 (idle), +1 (down)\n    @property\n    def rect(self) -&gt; pygame.Rect:\n        """Return the pygame.Rect of the paddle."""\n        return self._rect\n    @property\n    def center_y(self) -&gt; float:\n        """Vertical center of the paddle."""\n        return self._rect.centery\n    def move(self, direction: int) -&gt; None:\n        """\n        Set movement direction.\n        Args:\n            direction: -1 for up, 0 for idle, +1 for down.\n        """\n        if direction &lt; 0:\n            self._direction = -1\n        elif direction &gt; 0:\n            self._direction = 1\n        else:\n            self._direction = 0\n    def update(self, dt: float) -&gt; None:\n        """\n        Move the paddle based on the current direction and clamp to screen bounds.\n        Args:\n            dt: Delta time in seconds.\n        """\n        dy = self.speed * dt * self._direction\n        if dy != 0.0:\n            self._rect.y += int(dy)\n            # Continuous movement needs precise clamping\n            if self._rect.top &lt; 0:\n                self._rect.top = 0\n            if self._rect.bottom &gt; self.screen_height:\n                self._rect.bottom = self.screen_height\n    def draw(self, surface: pygame.Surface, color=(240, 240, 240)) -&gt; None:\n        """\n        Draw the paddle on the given surface.\n        Args:\n            surface: Destination surface.\n            color: RGB color tuple.\n        """\n        pygame.draw.rect(surface, color, self._rect)\nclass Ball:\n    """\n    Represents the Pong ball with simple 2D physics and collision handling.\n    """\n    def __init__(self, x: float, y: float, radius: int, speed: float, screen_width: int, screen_height: int,\n                 max_speed: float = 900.0, speedup_factor: float = 1.06):\n        """\n        Initialize the ball.\n        Args:\n            x: Initial x coordinate (center).\n            y: Initial y coordinate (center).\n            radius: Ball radius in pixels.\n            speed: Initial speed magnitude.\n            screen_width: Screen width boundary.\n            screen_height: Screen height boundary.\n            max_speed: Maximum speed magnitude.\n            speedup_factor: Multiplier applied on paddle hits.\n        """\n        self.x = float(x)\n        self.y = float(y)\n        self.radius = int(radius)\n        self.vx = float(speed)  # will be oriented by reset()\n        self.vy = 0.0\n        self.screen_width = screen_width\n        self.screen_height = screen_height\n        self.base_speed = float(speed)\n        self.max_speed = float(max_speed)\n        self.speedup_factor = float(speedup_factor)\n        # Initialize with a random direction\n        self.reset(self.screen_width / 2, self.screen_height / 2, direction=None)\n    def get_rect(self) -&gt; pygame.Rect:\n        """\n        Get a rect that bounds the ball for collision detection.\n        """\n        return pygame.Rect(int(self.x - self.radius), int(self.y - self.radius),\n                           self.radius * 2, self.radius * 2)\n    def reset(self, center_x: float, center_y: float, direction: int | None = None) -&gt; None:\n        """\n        Reset ball to the center and set a new random or specified launch direction.\n        Args:\n            center_x: New center x.\n            center_y: New center y.\n            direction: If -1 launch left, +1 launch right, None to randomize.\n        """\n        self.x = float(center_x)\n        self.y = float(center_y)\n        # Determine horizontal direction\n        if direction is None:\n            dir_x = random.choice([-1, 1])\n        else:\n            dir_x = -1 if direction &lt; 0 else 1\n        # Randomize initial vertical component within a sensible range\n        angle = random.uniform(-0.35, 0.35)  # about +/- 20 degrees\n        speed = self.base_speed\n        self.vx = math.cos(angle) * speed * dir_x\n        self.vy = math.sin(angle) * speed\n    def _normalize_velocity(self, speed: float) -&gt; None:\n        """\n        Normalize current velocity to the given speed magnitude.\n        """\n        mag = math.hypot(self.vx, self.vy)\n        if mag == 0:\n            # Avoid division by zero; give a slight nudge\n            self.vx, self.vy = speed, 0.0\n            return\n        scale = speed / mag\n        self.vx *= scale\n        self.vy *= scale\n    def _increase_speed(self) -&gt; None:\n        """\n        Increase speed after paddle hit, clamped to max_speed.\n        """\n        current_speed = math.hypot(self.vx, self.vy)\n        new_speed = min(self.max_speed, current_speed * self.speedup_factor)\n        self._normalize_velocity(new_speed)\n    def _bounce_vertical(self) -&gt; None:\n        """\n        Reflect vertical velocity and clamp within screen.\n        """\n        self.vy = -self.vy\n        # Clamp inside screen to avoid sticking\n        if self.y - self.radius &lt; 0:\n            self.y = self.radius\n        if self.y + self.radius &gt; self.screen_height:\n            self.y = self.screen_height - self.radius\n    def _handle_paddle_collision(self, paddle: Paddle, is_left: bool) -&gt; None:\n        """\n        Reflect off the given paddle and adjust trajectory based on impact point.\n        Args:\n            paddle: The paddle collided with.\n            is_left: True if left paddle, False if right paddle.\n        """\n        pre_vx_sign = -1 if is_left else 1  # vx should become positive after left, negative after right\n        # Compute relative impact point (-1 at top, +1 at bottom)\n        rel = (self.y - paddle.center_y) / (paddle.rect.height / 2.0)\n        rel = _clamp(rel, -1.0, 1.0)\n        # Target speed after collision (with speed-up)\n        self._increase_speed()\n        speed = math.hypot(self.vx, self.vy)\n        # Set vy influenced by where it hit the paddle, then recompute vx to maintain speed\n        self.vy = rel * speed * 0.8  # 80% of speed to vertical component based on impact\n        # Ensure not all vertical; compute vx to keep speed magnitude\n        horiz = max(0.2, math.sqrt(max(0.0, speed * speed - self.vy * self.vy)))\n        self.vx = horiz * (1 if pre_vx_sign &gt; 0 else -1)\n        # Nudge the ball outside the paddle to avoid sticking\n        if is_left:\n            self.x = paddle.rect.right + self.radius + 0.01\n        else:\n            self.x = paddle.rect.left - self.radius - 0.01\n    def update(self, dt: float, left_paddle: Paddle, right_paddle: Paddle) -&gt; None:\n        """\n        Update the ball position and handle collisions.\n        Args:\n            dt: Delta time in seconds.\n            left_paddle: Left player\'s paddle.\n            right_paddle: Right player\'s paddle.\n        """\n        # Move\n        self.x += self.vx * dt\n        self.y += self.vy * dt\n        # Top/bottom wall collisions\n        if self.y - self.radius &lt;= 0 or self.y + self.radius &gt;= self.screen_height:\n            self._bounce_vertical()\n        # Paddle collisions: check rect overlap and direction to reduce false positives\n        ball_rect = self.get_rect()\n        # Left paddle collision\n        if self.vx &lt; 0 and ball_rect.colliderect(left_paddle.rect):\n            self._handle_paddle_collision(left_paddle, is_left=True)\n        # Right paddle collision\n        ball_rect = self.get_rect()  # refresh after potential adjustment\n        if self.vx &gt; 0 and ball_rect.colliderect(right_paddle.rect):\n            self._handle_paddle_collision(right_paddle, is_left=False)\n    def draw(self, surface: pygame.Surface, color=(240, 240, 240)) -&gt; None:\n        """\n        Draw the ball on the given surface.\n        Args:\n            surface: Destination surface.\n            color: RGB color tuple.\n        """\n        pygame.draw.circle(surface, color, (int(self.x), int(self.y)), self.radius)\n\n\ngame.py\npython\n\'\'\'\nGame orchestration: input handling, game loop, scoring, serve cooldown,\nrendering, and win state management.\n\'\'\'\nimport time\nimport pygame\nfrom settings import (\n    SCREEN_WIDTH, SCREEN_HEIGHT, WINDOW_TITLE,\n    COLOR_BG, COLOR_FG, COLOR_DIM, COLOR_ACCENT,\n    PADDLE_WIDTH, PADDLE_HEIGHT, PADDLE_SPEED,\n    BALL_RADIUS, BALL_START_SPEED, BALL_MAX_SPEED, BALL_SPEEDUP_FACTOR,\n    WINNING_SCORE, SERVE_COOLDOWN_MS, FPS,\n    SCORE_FONT_SIZE, INFO_FONT_SIZE, WIN_FONT_SIZE,\n    CENTER_DASH_HEIGHT, CENTER_DASH_GAP\n)\nfrom entities import Paddle, Ball\nclass Game:\n    """\n    Main game controller for Two-Player Pong.\n    """\n    def __init__(self):\n        """Initialize pygame, window, entities, fonts, and game state."""\n        pygame.init()\n        pygame.display.set_caption(WINDOW_TITLE)\n        self.screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))\n        self.clock = pygame.time.Clock()\n        # Fonts\n        self.score_font = pygame.font.SysFont(None, SCORE_FONT_SIZE)\n        self.info_font = pygame.font.SysFont(None, INFO_FONT_SIZE)\n        self.win_font = pygame.font.SysFont(None, WIN_FONT_SIZE)\n        # Entities\n        margin = 24\n        left_x = margin\n        right_x = SCREEN_WIDTH - margin - PADDLE_WIDTH\n        center_y = SCREEN_HEIGHT // 2 - PADDLE_HEIGHT // 2\n        self.left_paddle = Paddle(left_x, center_y, PADDLE_WIDTH, PADDLE_HEIGHT, PADDLE_SPEED, SCREEN_HEIGHT)\n        self.right_paddle = Paddle(right_x, center_y, PADDLE_WIDTH, PADDLE_HEIGHT, PADDLE_SPEED, SCREEN_HEIGHT)\n        center_x = SCREEN_WIDTH / 2\n        center_y = SCREEN_HEIGHT / 2\n        self.ball = Ball(center_x, center_y, BALL_RADIUS, BALL_START_SPEED,\n                         SCREEN_WIDTH, SCREEN_HEIGHT, max_speed=BALL_MAX_SPEED, speedup_factor=BALL_SPEEDUP_FACTOR)\n        # Game state\n        self.left_score = 0\n        self.right_score = 0\n        self.game_over = False\n        # Serve cooldown after scoring\n        self.ball_active = True\n        self.serve_resume_time = 0  # pygame time in ms when ball resumes\n        # Movement directions\n        self.left_dir = 0\n        self.right_dir = 0\n    def process_input(self) -&gt; bool:\n        """\n        Process events and continuous keypress states.\n        Returns:\n            False to exit the game loop, True to continue running.\n        """\n        for event in pygame.event.get():\n            if event.type == pygame.QUIT:\n                return False\n            if event.type == pygame.KEYDOWN:\n                if event.key == pygame.K_ESCAPE:\n                    return False\n                if self.game_over and event.key == pygame.K_r:\n                    self.reset_match()\n        # Continuous key states\n        keys = pygame.key.get_pressed()\n        # Left paddle: W/S\n        up_left = keys[pygame.K_w]\n        down_left = keys[pygame.K_s]\n        # Right paddle: Up/Down\n        up_right = keys[pygame.K_UP]\n        down_right = keys[pygame.K_DOWN]\n        self.left_dir = (-1 if up_left else 0) + (1 if down_left else 0)\n        self.right_dir = (-1 if up_right else 0) + (1 if down_right else 0)\n        # Normalize directions to -1, 0, or 1\n        self.left_dir = max(-1, min(1, self.left_dir))\n        self.right_dir = max(-1, min(1, self.right_dir))\n        return True\n    def reset_round(self, scored_by: str) -&gt; None:\n        """\n        Handle actions after a point is scored.\n        Args:\n            scored_by: "left" or "right" indicating who scored.\n        """\n        if scored_by == "left":\n            self.left_score += 1\n        elif scored_by == "right":\n            self.right_score += 1\n        # Check win condition\n        if self.left_score &gt;= WINNING_SCORE or self.right_score &gt;= WINNING_SCORE:\n            self.game_over = True\n            self.ball_active = False\n            return\n        # Center paddles slightly towards center to reduce runaway\n        # (Optional: not necessary for gameplay)\n        # Reset ball and start serve cooldown\n        direction = -1 if scored_by == "right" else 1  # serve toward the player who conceded last\n        self.ball.reset(SCREEN_WIDTH / 2, SCREEN_HEIGHT / 2, direction=direction)\n        self.ball_active = False\n        self.serve_resume_time = pygame.time.get_ticks() + SERVE_COOLDOWN_MS\n    def reset_match(self) -&gt; None:\n        """\n        Reset scores, ball, paddles, and state for a new match.\n        """\n        self.left_score = 0\n        self.right_score = 0\n        self.game_over = False\n        self.left_paddle.rect.centery = SCREEN_HEIGHT // 2\n        self.right_paddle.rect.centery = SCREEN_HEIGHT // 2\n        self.ball.reset(SCREEN_WIDTH / 2, SCREEN_HEIGHT / 2, direction=None)\n        self.ball_active = False\n        self.serve_resume_time = pygame.time.get_ticks() + 800  # brief start delay\n    def update(self, dt: float) -&gt; None:\n        """\n        Update the game world for a single frame.\n        Args:\n            dt: Delta time in seconds.\n        """\n        # Move paddles\n        self.left_paddle.move(self.left_dir)\n        self.right_paddle.move(self.right_dir)\n        self.left_paddle.update(dt)\n        self.right_paddle.update(dt)\n        if self.game_over:\n            return\n        # Handle serve cooldown\n        if not self.ball_active:\n            if pygame.time.get_ticks() &gt;= self.serve_resume_time:\n                self.ball_active = True\n            else:\n                return  # Wait until cooldown finishes\n        # Update ball\n        self.ball.update(dt, self.left_paddle, self.right_paddle)\n        # Scoring: ball exits left or right\n        if self.ball.x + self.ball.radius &lt; 0:\n            # Right player scores\n            self.reset_round("right")\n        elif self.ball.x - self.ball.radius &gt; SCREEN_WIDTH:\n            # Left player scores\n            self.reset_round("left")\n    def render_center_line(self) -&gt; None:\n        """\n        Draw a dashed vertical center line.\n        """\n        dash_h = CENTER_DASH_HEIGHT\n        gap = CENTER_DASH_GAP\n        x = SCREEN_WIDTH // 2 - 2\n        y = 0\n        color = COLOR_DIM\n        while y &lt; SCREEN_HEIGHT:\n            rect = pygame.Rect(x, y, 4, dash_h)\n            pygame.draw.rect(self.screen, color, rect)\n            y += dash_h + gap\n    def render_scores(self) -&gt; None:\n        """\n        Render the scores for both players at the top of the screen.\n        """\n        left_surf = self.score_font.render(str(self.left_score), True, COLOR_FG)\n        right_surf = self.score_font.render(str(self.right_score), True, COLOR_FG)\n        # Positions\n        self.screen.blit(left_surf, (SCREEN_WIDTH * 0.25 - left_surf.get_width() / 2, 20))\n        self.screen.blit(right_surf, (SCREEN_WIDTH * 0.75 - right_surf.get_width() / 2, 20))\n    def render_status(self) -&gt; None:\n        """\n        Render status messages (cooldown or win).\n        """\n        if self.game_over:\n            winner = "Left Player" if self.left_score &gt; self.right_score else "Right Player"\n            win_text = f"{winner} Wins!"\n            info_text = "Press R to restart • Esc to quit"\n            win_surf = self.win_font.render(win_text, True, COLOR_ACCENT)\n            info_surf = self.info_font.render(info_text, True, COLOR_DIM)\n            cx = SCREEN_WIDTH // 2\n            cy = SCREEN_HEIGHT // 2\n            self.screen.blit(win_surf, (cx - win_surf.get_width() // 2, cy - 40))\n            self.screen.blit(info_surf, (cx - info_surf.get_width() // 2, cy + 10))\n            return\n        if not self.ball_active:\n            remaining_ms = max(0, self.serve_resume_time - pygame.time.get_ticks())\n            remaining = int((remaining_ms / 1000.0) + 0.9)  # round up display\n            ready_text = f"Get ready... {remaining}"\n            info_surf = self.info_font.render(ready_text, True, COLOR_DIM)\n            cx = SCREEN_WIDTH // 2\n            cy = SCREEN_HEIGHT // 2\n            self.screen.blit(info_surf, (cx - info_surf.get_width() // 2, cy - info_surf.get_height() // 2))\n        # Controls hint at bottom\n        hint_text = "Left: W/S • Right: ↑/↓ • Esc: Quit"\n        hint_surf = self.info_font.render(hint_text, True, (100, 100, 110))\n        self.screen.blit(hint_surf, (SCREEN_WIDTH // 2 - hint_surf.get_width() // 2, SCREEN_HEIGHT - 32))\n    def render(self) -&gt; None:\n        """\n        Render the entire frame (background, center line, entities, UI).\n        """\n        self.screen.fill(COLOR_BG)\n        self.render_center_line()\n        # Draw entities\n        self.left_paddle.draw(self.screen, COLOR_FG)\n        self.right_paddle.draw(self.screen, COLOR_FG)\n        if self.ball_active or self.game_over or True:\n            # Always draw ball (even during cooldown) so players see the serve position\n            self.ball.draw(self.screen, COLOR_FG)\n        # UI\n        self.render_scores()\n        self.render_status()\n        pygame.display.flip()\n    def run(self) -&gt; None:\n        """\n        Main loop: process input, update simulation, and render at target FPS.\n        """\n        running = True\n        # Brief initial delay to let players get ready\n        self.ball_active = False\n        self.serve_resume_time = pygame.time.get_ticks() + 800\n        while running:\n            running = self.process_input()\n            dt = self.clock.tick(FPS) / 1000.0\n            self.update(dt)\n            self.render()\n\n\n', 'images': '', 'comments': 'Highest-priority comment: The ball’s horizontal direction after paddle collisions is reversed, causing it to continue into the paddle (and potentially jitter/stick), making the game unplayable.\n\nHow to fix:\nIn entities.py, correct the horizontal velocity sign in Ball._handle_paddle_collision. Replace the current pre_vx_sign logic with a post-collision sign that points away from the paddle.\n\nSuggested revision:\n- Remove pre_vx_sign and set vx to be positive after hitting the left paddle and negative after hitting the right paddle.\n\nPatch snippet:\ndef _handle_paddle_collision(self, paddle: Paddle, is_left: bool) -&gt; None:\n    # Compute relative impact point (-1 at top, +1 at bottom)\n    rel = (self.y - paddle.center_y) / (paddle.rect.height / 2.0)\n    rel = _clamp(rel, -1.0, 1.0)\n\n    # Increase speed and compute target magnitude\n    self._increase_speed()\n    speed = math.hypot(self.vx, self.vy)\n\n    # Vertical component influenced by impact point\n    self.vy = rel * speed * 0.8\n\n    # Horizontal component must point away from the paddle\n    horiz = max(0.2, math.sqrt(max(0.0, speed * speed - self.vy * self.vy)))\n    self.vx = horiz * (1 if is_left else -1)\n\n    # Nudge the ball outside the paddle to avoid sticking\n    if is_left:\n        self.x = paddle.rect.right + self.radius + 0.01\n    else:\n        self.x = paddle.rect.left 