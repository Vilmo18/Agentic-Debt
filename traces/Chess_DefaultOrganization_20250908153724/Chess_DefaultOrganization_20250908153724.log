main.py
```python
'''
Terminal entry point for ChatDev Chess. Playable entirely in a Linux terminal.
Accepts SAN (e.g., Ke8, O-O, exd5=Q+) or coordinate moves (e2e4, g7g8q).
Includes standard chess features: castling, en passant, promotion, and enforces check/checkmate.
'''
from engine.board import Board
from engine.san import parse_user_input, generate_san_for_move


def print_status(board: Board):
    turn = "White" if board.white_to_move else "Black"
    status = f"{turn} to move"
    if board.in_check(board.white_to_move):
        status += " - Check"
    print(status)


def print_result(board: Board):
    if board.is_checkmate():
        winner = "Black" if board.white_to_move else "White"
        print(f"Checkmate! {winner} wins.")
        return True
    if board.is_stalemate():
        print("Stalemate. Draw.")
        return True
    return False


def main():
    board = Board()
    board.setup_start_position()
    print("ChatDev Chess (terminal).")
    print("Enter moves in SAN (e.g., Ke8, O-O, exd5=Q+) or coordinates (e2e4, g7g8q).")
    print("Type 'help' for commands.")
    while True:
        board.print_board()
        if print_result(board):
            break
        print_status(board)
        try:
            text = input("> ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nGoodbye.")
            break
        if not text:
            continue
        lower = text.lower()
        if lower in ("q", "quit", "exit"):
            print("Goodbye.")
            break
        if lower in ("h", "help"):
            print("Commands:")
            print("  help - show this help")
            print("  list - list all legal moves in SAN")
            print("  quit - exit the game")
            print("Input formats:")
            print("  SAN examples: Ke8, O-O, O-O-O, exd5=Q+, Rxa7#")
            print("  Coordinates: e2e4, g7g8q (promotion), a7a8 (promotion defaults to queen)")
            continue
        if lower in ("l", "list"):
            moves = board.generate_legal_moves()
            sans = [generate_san_for_move(board, mv, moves) for mv in moves]
            print("Legal moves:", ", ".join(sorted(sans)))
            continue
        mv = parse_user_input(board, text)
        if mv is None:
            print("Invalid or illegal move. Type 'list' to see legal moves.")
            continue
        board.make_move(mv)
    print("Game over.")


if __name__ == "__main__":
    main()
