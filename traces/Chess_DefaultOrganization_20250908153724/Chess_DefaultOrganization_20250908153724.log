{\n        \'K\': \'♔\', \'Q\': \'♕\', \'R\': \'♖\', \'B\': \'♗\', \'N\': \'♘\', \'P\': \'♙\',\n        \'k\': \'♚\', \'q\': \'♛\', \'r\': \'♜\', \'b\': \'♝\', \'n\': \'♞\', \'p\': \'♟\',\n    }\n    return mapping.get(piece, \'?\')\n\n\n', 'requirements': 'requirements.txt\n\n# Standard library only; no third-party packages required.\n# Optional backport for Python &lt; 3.7:\ndataclasses; python_version &lt; "3.7"\n\n\n\n'} |
