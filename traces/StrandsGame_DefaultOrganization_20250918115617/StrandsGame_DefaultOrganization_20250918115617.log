'''
Styles for the Strands puzzle UI. Designed to be clean and responsive.
'''
/* Styles for the Strands puzzle UI. Designed to be clean and responsive. */
:root {
  --bg: #0f172a;
  --card: #111827;
  --chip: #1f2937;
  --chip-active: #0ea5e9;
  --chip-text: #e5e7eb;
  --text: #e5e7eb;
  --muted: #94a3b8;
  --border: #374151;
  --accent: #22c55e;
  --warn: #f59e0b;
  --error: #ef4444;
}
* {
  box-sizing: border-box;
}
body {
  margin: 0;
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji",
    "Segoe UI Emoji";
  background: linear-gradient(180deg, #0b1022, #0d1326 30%, #0f172a);
  color: var(--text);
}
.page {
  max-width: 1100px;
  margin: 0 auto;
  padding: 16px;
}
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}
.header h1 {
  margin: 0;
  font-size: 28px;
  letter-spacing: 0.5px;
}
.header-actions {
  display: flex;
  gap: 8px;
  align-items: center;
}
.header-actions select,
.header-actions button {
  background: var(--card);
  color: var(--text);
  border: 1px solid var(--border);
  padding: 8px 10px;
  border-radius: 8px;
  cursor: pointer;
}
.header-actions button:hover {
  border-color: var(--chip-active);
}
.info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 10px 12px;
  margin-bottom: 12px;
}
.theme {
  font-weight: 600;
}
.progress {
  color: var(--muted);
}
.main {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 16px;
}
.board,
.sidebar {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px;
}
.board h2,
.sidebar h2 {
  margin-top: 0;
  font-size: 18px;
  color: #f3f4f6;
}
.bag,
.assemble {
  min-height: 110px;
  border: 1px dashed var(--border);
  padding: 10px;
  border-radius: 8px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
  background: rgba(255, 255, 255, 0.02);
}
.assemble {
  min-height: 72px;
}
.assemble.dropping {
  border-color: var(--chip-active);
  background: rgba(14, 165, 233, 0.08);
}
.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 10px;
  background: var(--chip);
  color: var(--chip-text);
  border-radius: 999px;
  user-select: none;
  border: 1px solid var(--border);
  letter-spacing: 0.5px;
  min-width: 36px;
  font-weight: 600;
}
.chip.active {
  background: var(--chip-active);
  color: #001b2a;
  border-color: transparent;
}
.bag-actions,
.assemble-actions {
  display: flex;
  gap: 8px;
  margin: 8px 0 14px;
}
button {
  background: var(--chip);
  color: var(--chip-text);
  border: 1px solid var(--border);
  padding: 8px 12px;
  border-radius: 10px;
  cursor: pointer;
  font-weight: 600;
}
button.primary {
  background: var(--accent);
  color: #00140a;
  border-color: transparent;
}
button:hover {
  filter: brightness(1.05);
}
.feedback {
  margin-top: 10px;
  padding: 10px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.02);
}
.feedback.success {
  border-color: #16a34a;
  background: rgba(34, 197, 94, 0.15);
}
.feedback.info {
  border-color: #38bdf8;
  background: rgba(56, 189, 248, 0.15);
}
.feedback.warn {
  border-color: var(--warn);
  background: rgba(245, 158, 11, 0.15);
}
.feedback.error {
  border-color: var(--error);
  background: rgba(239, 68, 68, 0.15);
}
.found-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.found-list li {
  margin: 6px 0;
  padding: 6px 10px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border);
  border-radius: 8px;
  font-weight: 600;
}
.complete {
  margin-top: 12px;
  padding: 10px;
  text-align: center;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: rgba(34, 197, 94, 0.15);
  color: #d1fae5;
  font-weight: 700;
}
.hidden {
  display: none;
}
.footer {
  margin-top: 16px;
  display: flex;
  justify-content: space-between;
  color: var(--muted);
}
@media (max-width: 900px) {
  .main {
    grid-template-columns: 1fr;
  }
}
