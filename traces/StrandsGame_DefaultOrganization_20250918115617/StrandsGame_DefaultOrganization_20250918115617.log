}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 10px;
  background: var(--chip);
  color: var(--chip-text);
  border-radius: 999px;
  user-select: none;
  border: 1px solid var(--border);
  letter-spacing: 0.5px;
  min-width: 36px;
  font-weight: 600;
}

.chip.active {
  background: var(--chip-active);
  color: #001b2a;
  border-color: transparent;
}

.bag-actions,
.assemble-actions {
  display: flex;
  gap: 8px;
  margin: 8px 0 14px;
}

button {
  background: var(--chip);
  color: var(--chip-text);
  border: 1px solid var(--border);
  padding: 8px 12px;
  border-radius: 10px;
