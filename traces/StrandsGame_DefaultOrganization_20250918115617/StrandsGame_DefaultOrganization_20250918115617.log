'''
Styles for the Strands puzzle UI. Designed to be clean and responsive.
'''
/* Styles for the Strands puzzle UI. Designed to be clean and responsive. */
:root {
  --bg: #0f172a;
  --card: #111827;
  --chip: #1f2937;
  --chip-active: #0ea5e9;
  --chip-text: #e5e7eb;
  --text: #e5e7eb;
  --muted: #94a3b8;
  --border: #374151;
  --accent: #22c55e;
  --warn: #f59e0b;
  --error: #ef4444;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji",
    "Segoe UI Emoji";
  background: linear-gradient(180deg, #0b1022, #0d1326 30%, #0f172a);
  color: var(--text);
}

.page {
  max-width: 1100px;
  margin: 0 auto;
  padding: 16px;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.header h1 {
  margin: 0;
  font-size: 28px;
  letter-spacing: 0.5px;
}

.header-actions {
  display: flex;
  gap: 8px;
  align-items: center;
}

.header-actions select,
.header-actions button {
  background: var(--card);
  color: var(--text);
  border: 1px solid var(--border);
  padding: 8px 10px;
  border-radius: 8px;
  cursor: pointer;
}

.header-actions button:hover {
  border-color: var(--chip-active);
}

.info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 10px 12px;
  margin-bottom: 12px;
}

.theme {
  font-weight: 600;
}

.progress {
  color: var(--muted);
}

.main {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 16px;
}

.board,
.sidebar {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px;
}

.board h2,
.sidebar h2 {
  margin-top: 0;
  font-size: 18px;
  color: #f3f4f6;
}

.bag,
.assemble {
  min-height: 110px;
  border: 1px dashed var(--border);
  padding: 10px;
  border-radius: 8px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
  background: rgba(255, 255, 255, 0.02);
}

.assemble {
  min-height: 72px;
}

.assemble.dropping {
  border-color: var(--chip-active);
