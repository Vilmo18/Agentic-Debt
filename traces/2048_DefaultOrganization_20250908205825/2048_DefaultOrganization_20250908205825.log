'''
:root {
  --cell-size: 90px;
  --cell-gap: 12px;
  --board-padding: 12px;
  --board-bg: #bbada0;
  --tile-bg: #cdc1b4;
  --tile-empty-opacity: 0.35;
  --text-color-dark: #776e65;
  --text-color-light: #f9f6f2;
  --font-main: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
}
* { box-sizing: border-box; }
body {
  margin: 0;
  padding: 0;
  font-family: var(--font-main);
  background: #faf8ef;
  color: var(--text-color-dark);
  display: flex;
  min-height: 100vh;
}
.app {
  margin: auto;
  width: calc(var(--cell-size) * 4 + var(--cell-gap) * 5 + var(--board-padding) * 2);
  max-width: 95vw;
}
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.header h1 {
  font-size: 44px;
  margin: 16px 0;
}
.scores {
  display: flex;
  gap: 10px;
}
.score-box {
  background: #bbada0;
  color: #fff;
  padding: 8px 14px;
  border-radius: 6px;
  min-width: 90px;
  text-align: center;
}
.score-box .label {
  font-size: 12px;
  text-transform: uppercase;
  opacity: 0.9;
}
.score-box .value {
  font-size: 22px;
  font-weight: bold;
}
.controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}
.btn {
  background: #8f7a66;
  color: white;
  border: none;
  padding: 10px 16px;
  border-radius: 6px;
  cursor: pointer;
  font-weight: bold;
}
.btn:hover {
  filter: brightness(1.05);
}
.hint {
  font-size: 14px;
  opacity: 0.8;
}
.board-wrapper {
  position: relative;
}
.board {
  position: relative;
  background: var(--board-bg);
  border-radius: 8px;
  padding: var(--board-padding);
  display: grid;
  grid-template-columns: repeat(var(--size, 4), var(--cell-size));
  grid-template-rows: repeat(var(--size, 4), var(--cell-size));
  gap: var(--cell-gap);
  width: calc(var(--cell-size) * var(--size, 4) + var(--cell-gap) * (var(--size, 4) - 1) + var(--board-padding) * 2);
  height: calc(var(--cell-size) * var(--size, 4) + var(--cell-gap) * (var(--size, 4) - 1) + var(--board-padding) * 2);
}
.tile {
  width: var(--cell-size);
  height: var(--cell-size);
