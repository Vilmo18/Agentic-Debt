'''
Shared constants for geometry, colors, and settings.
'''
# Geometry and timing
ROWS = 8
COLS = 8
SQUARE_SIZE = 80
BOARD_SIZE = SQUARE_SIZE * ROWS
PANEL_HEIGHT = 110
WIDTH = BOARD_SIZE
HEIGHT = BOARD_SIZE + PANEL_HEIGHT
FPS = 60

# Colors
BG_COLOR = (18, 18, 18)
LIGHT_COLOR = (230, 210, 180)
DARK_COLOR = (139, 69, 19)
RED_COLOR = (220, 50, 50)
BLACK_COLOR = (30, 30, 30)
KING_TEXT_COLOR = (255, 255, 0)
HILITE_MOVE_COLOR = (50, 180, 255)
HILITE_CAPTURE_COLOR = (255, 140, 0)
TEXT_COLOR = (235, 235, 235)
INFO_TEXT_COLOR = (180, 180, 180)
STATUS_OK_COLOR = (80, 200, 120)
STATUS_ERR_COLOR = (255, 80, 80)
INPUT_BG_COLOR = (40, 40, 40)
INPUT_BORDER_COLOR = (90, 90, 90)
INPUT_ACTIVE_BORDER_COLOR = (140, 140, 140)
