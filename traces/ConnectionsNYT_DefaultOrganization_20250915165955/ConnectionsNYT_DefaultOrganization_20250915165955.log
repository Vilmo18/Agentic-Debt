```python
'''
Streamlit web app for the daily 4x4 word grouping puzzle game.
Renders a browser-based UI, loads the daily puzzle, and manages gameplay:
selection, submission, feedback, shuffling, mistakes, and revealing solved groups.
'''
import random
from typing import List, Set

import streamlit as st

from puzzle import Puzzle, generate_daily_puzzle, get_color_for_difficulty
from utils import today_date_str


# -------------------------
# Session State Management
# -------------------------
def init_state():
    """Initialize session state for a new or fresh session."""
    if "initialized" in st.session_state and st.session_state.initialized:
        return

    puzzle: Puzzle = generate_daily_puzzle()
    st.session_state.puzzle = puzzle
    st.session_state.date_str = today_date_str()

    # Gameplay state
    st.session_state.remaining_words: List[str] = list(puzzle.words)  # shuffled daily words
    st.session_state.selected_words: Set[str] = set()
    st.session_state.solved_categories: Set[int] = set()
    st.session_state.solved_order: List[int] = []
    st.session_state.mistakes: int = 0
    st.session_state.max_mistakes: int = 4
    st.session_state.game_finished: bool = False

    # UI feedback
    st.session_state.feedback_text: str = ""
    st.session_state.feedback_type: str = "info"  # one of: 'info','success','error','warning'

    st.session_state.initialized = True


def reset_today():
    """Reset today's puzzle to its initial state (deterministic for the day)."""
    puzzle: Puzzle = generate_daily_puzzle()
    st.session_state.puzzle = puzzle
    st.session_state.date_str = today_date_str()
    st.session_state.remaining_words = list(puzzle.words)
    st.session_state.selected_words = set()
    st.session_state.solved_categories = set()
    st.session_state.solved_order = []
    st.session_state.mistakes = 0
    st.session_state.max_mistakes = 4
    st.session_state.game_finished = False
    st.session_state.feedback_text = ""
    st.session_state.feedback_type = "info"


# -------------------------
# Gameplay Helpers
# -------------------------
def set_feedback(text: str, ftype: str = "info"):
    st.session_state.feedback_text = text
    st.session_state.feedback_type = ftype


def deselect_all():
    st.session_state.selected_words.clear()
    set_feedback("", "info")


def shuffle_words():
    if st.session_state.game_finished:
        return
    rng = random.Random()  # session-local nondeterministic shuffle
    rng.shuffle(st.session_state.remaining_words)


def handle_correct_group(cat_id: int):
    puzzle: Puzzle = st.session_state.puzzle
    # Remove words from remaining words
    words_to_remove = set(puzzle.categories[cat_id].words)
    st.session_state.remaining_words = [w for w in st.session_state.remaining_words if w not in words_to_remove]
    # Clear selection
    st.session_state.selected_words.clear()
    # Mark category solved
    if cat_id not in st.session_state.solved_categories:
        st.session_state.solved_categories.add(cat_id)
        st.session_state.solved_order.append(cat_id)

    cat = puzzle.categories[cat_id]
    set_feedback(f"Correct: {cat.name}", "success")
    # Check for win
    if len(st.session_state.solved_categories) == 4:
        st.session_state.game_finished = True
        set_feedback("You solved today's puzzle! Come back tomorrow.", "success")
        st.balloons()


def handle_incorrect_guess():
    st.session_state.mistakes += 1
    remaining = st.session_state.max_mistakes - st.session_state.mistakes
    if remaining > 0:
        set_feedback(f"Incorrect. {remaining} mistake(s) left.", "error")
    else:
        set_feedback("No mistakes left. Revealing solution...", "warning")
        game_over()


def submit_guess():
    if st.session_state.game_finished:
        return
    if len(st.session_state.selected_words) != 4:
        set_feedback("Select exactly four words.", "warning")
        return
    selection = list(st.session_state.selected_words)
    puzzle: Puzzle = st.session_state.puzzle
    cat_ids = {puzzle.word_to_category[w] for w in selection}
    if len(cat_ids) == 1:
        cat_id = next(iter(cat_ids))
        if cat_id in st.session_state.solved_categories:
            set_feedback("That group is already solved.", "info")
            return
        handle_correct_group(cat_id)
    else:
        handle_incorrect_guess()


def game_over():
    """Mark the game as finished and reveal all remaining categories."""
    st.session_state.game_finished = True
    # No need to modify remaining_words; panels will render all categories
    # Selection no longer matters
    st.session_state.selected_words.clear()


# -------------------------
# UI Rendering
# -------------------------
def render_header():
    st.title("Connections")
    st.caption(f"Daily Puzzle: {st.session_state.date_str}")


def render_status():
    mistakes = st.session_state.mistakes
    max_mistakes = st.session_state.max_mistakes
    st.write(f"Mistakes: {mistakes}/{max_mistakes}")

    # Feedback box
    if st.session_state.feedback_text:
        if st.session_state.feedback_type == "success":
            st.success(st.session_state.feedback_text)
        elif st.session_state.feedback_type == "error":
            st.error(st.session_state.feedback_text)
        elif st.session_state.feedback_type == "warning":
            st.warning(st.session_state.feedback_text)
        else:
            st.info(st.session_state.feedback_text)


def render_solved_panels():
    puzzle: Puzzle = st.session_state.puzzle
    # If game is over, reveal all categories; otherwise only solved ones
    if st.session_state.game_finished:
        to_show = list(range(4))
    else:
        to_show = st.session_state.solved_order

    if not to_show:
        return

    st.subheader("Solved Groups")
    for cid in to_show:
        cat = puzzle.categories[cid]
        color = get_color_for_difficulty(cat.difficulty)
        words_text = ", ".join(w.upper() for w in cat.words)
        html = f"""
        <div style="
            background-color: {color};
            padding: 10px 12px;
            border-radius: 6px;
            margin-bottom: 8px;
            color: #000;
            border: 1px solid rgba(0,0,0,0.2);
        ">
            <div style="font-weight: 700; font-size: 15px; margin-bottom: 4px;">
                {cat.name} ({cat.difficulty.title()})
            </div>
            <div style="font-size: 13px;">{words_text}</div>
        </div>
        """
        st.markdown(html, unsafe_allow_html=True)


def render_grid():
    remaining_words = st.session_state.remaining_words
    selected_words = st.session_state.selected_words
    game_finished = st.session_state.game_finished

    n = len(remaining_words)
    if n == 0:
        return

    cols = 4
    rows = (n + cols - 1) // cols

    st.subheader("Select Words")

    idx = 0
    for _ in range(rows):
        row_cols = st.columns(cols, gap="small")
        for c in range(cols):
            if idx < n:
                word = remaining_words[idx]
                label = word.upper()
                is_selected = word in selected_words
                # Use "primary" type to visually highlight selected words
                btn = row_cols[c].button(
                    label,
                    key=f"word-{word}",
                    type="primary" if is_selected else "secondary",
                    use_container_width=True,
                    disabled=game_finished,
                )
                if btn and not game_finished:
                    # Toggle selection with max limit of 4
                    if is_selected:
                        selected_words.remove(word)
                    else:
                        if len(selected_words) < 4:
                            selected_words.add(word)
                        else:
                            set_feedback("Select exactly four words.", "warning")
                idx += 1
            else:
                # Empty placeholder for consistent grid spacing
                row_cols[c].markdown("&nbsp;")
    st.divider()


def render_controls():
    cols = st.columns([1, 1, 1, 1, 2])
    with cols[0]:
        st.button(
            "Submit",
            on_click=submit_guess,
            disabled=(len(st.session_state.selected_words) != 4) or st.session_state.game_finished,
            use_container_width=True,
        )
    with cols[1]:
        st.button("Deselect All", on_click=deselect_all, use_container_width=True, disabled=st.session_state.game_finished)
    with cols[2]:
        st.button("Shuffle", on_click=shuffle_words, use_container_width=True, disabled=st.session_state.game_finished)
    with cols[3]:
        st.button("Reset Today", on_click=reset_today, use_container_width=True)
    with cols[4]:
        with st.expander("How to Play"):
            st.write(
                "- Group the 16 words into 4 categories of 4 words each.\n"
                "- Select exactly four words and press Submit.\n"
                "- Correct groups are removed and revealed with their category.\n"
                "- You have at most 4 mistakes.\n"
                "- Shuffle rearranges the remaining words.\n"
                "- A new puzzle is generated every day.\n"
                "Tip: Words may seem to fit multiple categories, but there is only one correct solution."
            )


# -------------------------
# App Entry
# -------------------------
def main():
    st.set_page_config(page_title="Daily Connections - 4x4 Word Groups", page_icon="🧩", layout="centered")
    init_state()
    render_header()
    render_status()
    render_solved_panels()
    render_grid()
    render_controls()


if __name__ == "__main__":
    main()
```

