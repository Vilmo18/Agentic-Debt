    # Sanity check for uniqueness across the entire bank
    seen = set()
    for cat in bank:
        for w in cat.words:
            lw = w.strip().lower()
            if lw in seen:
                raise ValueError(f"Duplicate word across category bank: {lw}")
            seen.add(lw)
    return bank
