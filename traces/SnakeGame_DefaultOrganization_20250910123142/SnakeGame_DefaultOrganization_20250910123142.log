        # Draw buttons
        for btn in buttons:
            btn.draw(screen)
        # Hints
        draw_text(
            screen,
            "Choose difficulty. ESC to quit.",
            font_hint,
            (200, 200, 200),
            (WIDTH // 2, HEIGHT - 40),
        )
        pygame.display.flip()
def main():
