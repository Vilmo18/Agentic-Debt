    Returns:
        A dict with keys: 'count', 'max', 'sum'.
        For an empty list, count is 0, max is 0, sum is 0.
    """
    if not seq:
        return {"count": 0, "max": 0, "sum": 0}
    return {"count": len(seq), "max": max(seq), "sum": sum(seq)}
