+    def _build_grid_buttons(self) -> None:
+        """Create the 3x3 grid of buttons."""
+        assert self.grid_frame is not None
+        self.buttons = []
+        for r in range(GRID_SIZE):
+            row_buttons: List[tk.Button] = []
+            for c in range(GRID_SIZE):
+                btn = tk.Button(
+                    self.grid_frame,
+                    text="",
+                    width=4,
+                    height=2,
